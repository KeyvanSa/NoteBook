<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:background="@drawable/bkg_dialog"
    android:layout_height="wrap_content">

    <TextView
        android:layout_height="wrap_content"
        android:textAppearance="?android:attr/textAppearanceLarge"
        android:layout_width="wrap_content"
        android:text="Choose Item"
        android:id="@+id/Title"
        android:layout_alignParentRight="true"
        android:textSize="25sp"
        android:textColor="#000000"
        android:layout_margin="10dp"/>

    <TextView
        android:layout_height="wrap_content"
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:layout_width="wrap_content"
        android:text="Which action should be performed on the selected note?"
        android:layout_below="@id/Title"
        android:layout_margin="10dp"
        android:layout_alignParentRight="true"
        android:layout_marginRight="20dp"
        android:textSize="15sp"
        android:textColor="#676564"
        android:ellipsize="start"
        android:id="@+id/Text"
        android:singleLine="true" />

    <Button
        android:id="@+id/Button_Pin_Note"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/Text"
        android:layout_marginStart="10dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bkg_button_first_type"
        android:text="Pin Note"
        android:textColor="@color/white"
        android:textSize="20sp" />

    <Button
        android:id="@+id/Button_Delete_Note"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/Text"
        android:layout_marginStart="10dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="10dp"
        android:layout_toRightOf="@id/Button_Pin_Note"
        android:background="@drawable/bkg_button_second_type"
        android:text="Delete Note"
        android:textColor="@color/purple_500"
        android:textSize="20sp" />

</RelativeLayout>