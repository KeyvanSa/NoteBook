<?xml version="1.0" encoding="UTF-8"?>

<selector 
	xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true" >

        <shape>

			<solid
				android:color="#458A8E8E"/>

			<corners 
				android:bottomRightRadius="5dp" 
				android:bottomLeftRadius="5dp" 
				android:topLeftRadius="5dp"
				android:topRightRadius="5dp"/> 
			
			<stroke
				android:width="2dp"
				android:color="@color/purple_500"/>

			<padding
				android:left="5dp"
				android:top="5dp"
				android:right="5dp"
				android:bottom="5dp" />

		</shape>

    </item>

    <item>

        <shape>

			<solid
				android:color="#00000000"/>

			<corners 
				android:bottomRightRadius="5dp" 
				android:bottomLeftRadius="5dp" 
				android:topLeftRadius="5dp"
				android:topRightRadius="5dp"/>

			<stroke
				android:width="2dp"
				android:color="@color/purple_500"/>

			<padding
				android:left="5dp"
				android:top="5dp"
				android:right="5dp"
				android:bottom="5dp" />

		</shape>

    </item>

</selector>
